# Docker image build settings
PYTHON_IMAGE=python:3.13-slim-bookworm
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
TORCH_PACKAGES=torch torchvision torchaudio
UID=1000
GID=1000
COMFYUI_IMAGE=zients/comfyui:local
COMFYUI_COMPOSE_PROJECT_NAME=comfyui

# Host networking. Default binds only to localhost.
COMFYUI_HOST=127.0.0.1
COMFYUI_HOST_PORT=8188
# CPU-only smoke example if you uncomment the comfyui-cpu service.
# COMFYUI_CPU_HOST=127.0.0.1
# COMFYUI_CPU_HOST_PORT=8189

# Host runtime directories are tracked with placeholder files where needed.
# ComfyUI temp files stay inside the container and are not bind-mounted.
COMFYUI_MODELS_DIR=./models
COMFYUI_CUSTOM_NODES_DIR=./custom_nodes
COMFYUI_INPUT_DIR=./input
COMFYUI_OUTPUT_DIR=./output
COMFYUI_USER_DIR=./user

# Default GPU service flags. Leave empty for normal CUDA startup.
COMFYUI_ARGS=

# CPU-only smoke flags if you uncomment the comfyui-cpu service.
# COMFYUI_CPU_ARGS=--cpu --disable-all-custom-nodes
